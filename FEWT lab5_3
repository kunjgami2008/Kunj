<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title></title>
</head>
<body>
	<script>

			a=parseInt(prompt("eneter no 1"));
			b=parseInt(prompt("eneter no 2"));

			c=prompt("enter your choice");

			switch(c)
			{
					case'+':
					alert( a + b);
					break;

					case'+':
					alert( a - b);
					break;

					case'+':
					alert( a * b);
					break;

					case'+':
					alert( a / b);
					break;
			}
	</script>

</body>
</html>
